{
  "name": "mbojarski/smart-diag-backend",
  "description": "Smart diagnostics backend API",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.2",
    "ext-ctype": "*",
    "ext-json": "*",
    "doctrine/doctrine-bundle": "^2.18",
    "doctrine/doctrine-migrations-bundle": "^3.7",
    "doctrine/orm": "^3.6",
    "predis/predis": "^2.3",
    "symfony/cache": "^7.0",
    "symfony/console": "^7.0",
    "symfony/dotenv": "^7.0",
    "symfony/framework-bundle": "^7.0",
    "symfony/http-client": "^7.0",
    "symfony/runtime": "^7.0",
    "symfony/yaml": "^7.0"
  },
  "require-dev": {
    "nelmio/api-doc-bundle": "^5.10",
    "phpstan/phpstan": "^2.2",
    "phpstan/phpstan-symfony": "^2.0",
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^4.0",
    "symfony/asset": "^7.0",
    "symfony/web-profiler-bundle": "^7.4"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd"
    },
    "analyse": "phpstan analyse --memory-limit=512M",
    "cs": "phpcs",
    "test": "phpunit",
    "check": [
      "@test",
      "@analyse",
      "@cs"
    ]
  },
  "config": {
    "allow-plugins": {
      "symfony/runtime": true,
      "symfony/flex": true
    },
    "sort-packages": true
  }
}
